<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIR Control</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body>
  <nav>
    <h1>DIR Control</h1>
    <a href="/admin">Dashboard</a>
    <a href="/admin/shows">Shows</a>
    <a href="/admin/visuals">Visuals</a>
    <a href="/admin/generation">Generate</a>
    <div style="flex:1"></div>
    <%= link_to "Sign out", admin_logout_path, method: :delete, style: "font-size:12px;color:rgba(216,212,203,0.25);margin-top:auto" %>
  </nav>
  <main>
    <% if notice %>
      <div class="flash notice"><%= notice %></div>
    <% end %>
    <%= yield %>
  </main>
</body>
</html>
