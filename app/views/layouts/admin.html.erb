<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIR Control</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "IBM Plex Mono", "Courier New", monospace;
      background: #d8d4cb;
      color: #1a1a1a;
      display: flex;
      min-height: 100vh;
    }
    nav {
      width: 240px;
      background: #1a1a1a;
      color: #d8d4cb;
      padding: 28px 20px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    nav h1 {
      font-size: 14px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #ff5a1f;
      margin-bottom: 24px;
      font-weight: 600;
    }
    nav a {
      color: rgba(216, 212, 203, 0.6);
      text-decoration: none;
      font-size: 15px;
      letter-spacing: 0.04em;
      padding: 8px 12px;
      border-radius: 4px;
      transition: color 0.15s, background 0.15s;
    }
    nav a:hover {
      color: #d8d4cb;
      background: rgba(255,255,255,0.06);
    }
    main {
      flex: 1;
      padding: 40px 48px;
      overflow-y: auto;
    }
    h2 {
      font-size: 24px;
      font-weight: 500;
      letter-spacing: 0.04em;
      margin-bottom: 24px;
      color: #1a1a1a;
    }
    h3 { font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(0,0,0,0.35); margin-bottom: 12px; }
    .stats { display: flex; gap: 24px; margin-bottom: 32px; }
    .stat-card {
      background: #e9e6df;
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 8px;
      padding: 24px 28px;
      min-width: 180px;
    }
    .stat-card .num {
      font-size: 36px;
      font-weight: 600;
      color: #ff5a1f;
    }
    .stat-card .label {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.35);
      margin-top: 6px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    th {
      text-align: left;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.35);
      padding: 10px 14px;
      border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    td {
      padding: 10px 14px;
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .notice {
      background: rgba(255, 90, 31, 0.1);
      border: 1px solid rgba(255, 90, 31, 0.2);
      border-radius: 6px;
      padding: 14px 20px;
      font-size: 13px;
      margin-bottom: 20px;
    }
    .status-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 3px;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .status-done, .status-complete { background: rgba(0,180,0,0.1); color: #00b400; }
    .status-running, .status-generating { background: rgba(255,180,0,0.1); color: #c89000; }
    .status-failed { background: rgba(255,0,0,0.1); color: #cc0000; }
    .status-pending, .status-draft { background: rgba(0,0,0,0.05); color: rgba(0,0,0,0.4); }
    a { color: #ff5a1f; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .flash { margin-bottom: 20px; font-size: 14px; }
    form { margin: 20px 0; }
    label { display: block; font-size: 13px; letter-spacing: 0.06em; color: rgba(0,0,0,0.5); margin-bottom: 6px; }
    input, select, textarea {
      font-family: "IBM Plex Mono", "Courier New", monospace;
      font-size: 14px;
      padding: 10px 14px;
      border: 1px solid rgba(0,0,0,0.12);
      border-radius: 4px;
      background: #e9e6df;
      margin-bottom: 16px;
      width: 400px;
    }
    input[type="checkbox"] {
      width: auto;
      padding: 0;
    }
    button, .btn {
      font-family: "IBM Plex Mono", "Courier New", monospace;
      font-size: 13px;
      letter-spacing: 0.06em;
      padding: 10px 24px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      background: #1a1a1a;
      color: #d8d4cb;
      transition: opacity 0.15s;
    }
    button:hover, .btn:hover { opacity: 0.8; }
    .btn-sm { font-size: 11px; padding: 6px 14px; }
    .ace-step-status {
      display: flex; align-items: center; gap: 8px;
      background: #e9e6df; border: 1px solid rgba(0,0,0,0.08);
      border-radius: 8px; padding: 16px 20px; margin-bottom: 32px;
    }
    .ace-step-status h3 { margin-bottom: 0; }
    .status-dot { font-size: 20px; line-height: 1; }
    .status-dot.running { color: #00b400; }
    .status-dot.stopped { color: rgba(0,0,0,0.25); }
    .status-dot.unknown { color: #c89000; }
    pre {
      background: #1a1a1a;
      color: #d8d4cb;
      padding: 16px;
      border-radius: 6px;
      font-size: 13px;
      overflow-x: auto;
      max-height: 400px;
    }
    .meta { font-size: 12px; color: rgba(0,0,0,0.35); margin-top: 6px; }
    code { font-family: "IBM Plex Mono", "Courier New", monospace; background: rgba(0,0,0,0.06); padding: 1px 6px; border-radius: 3px; font-size: 13px; }

    .tx-page {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 80px);
    }
    .tx-form {
      width: 100%;
      max-width: 600px;
    }
    .tx-form h2 {
      color: #1a1a1a;
      margin-bottom: 36px;
      text-align: center;
      font-size: 28px;
    }
    .tx-form form { margin: 0; }
    .tx-form label {
      color: rgba(0,0,0,0.45);
      display: block;
      font-size: 15px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .tx-form input, .tx-form select, .tx-form textarea {
      background: #e9e6df;
      border: 1px solid rgba(0,0,0,0.12);
      color: #1a1a1a;
      width: 100%;
      font-size: 20px;
      padding: 14px 16px;
    }
    .tx-form input:focus, .tx-form select:focus, .tx-form textarea:focus {
      outline: none;
      border-color: #ff5a1f;
      background: #e9e6df;
    }
    .tx-form .field { margin-bottom: 22px; }
    .tx-form .field-row {
      display: flex;
      gap: 20px;
    }
    .tx-form .field-row .field { flex: 1; }
    .tx-form .field-check {
      display: flex !important;
      align-items: center;
      gap: 10px;
      margin-bottom: 28px;
      cursor: pointer;
      color: rgba(0,0,0,0.5) !important;
      font-size: 16px !important;
    }
    .tx-form .field-check input[type="checkbox"] {
      width: 18px;
      height: 18px;
    }
    .btn-submit {
      display: block;
      width: 100%;
      padding: 18px;
      font-size: 18px;
      letter-spacing: 0.15em;
      background: #1a1a1a;
      color: #d8d4cb;
      font-weight: 600;
    }
    .btn-submit:hover { opacity: 0.85; }
    .tx-form .meta { text-align: center; color: rgba(0,0,0,0.3); font-size: 15px; margin-top: 12px; }
  </style>
</head>
<body>
  <nav>
    <h1>DIR Control</h1>
    <a href="/admin">Dashboard</a>
    <a href="/admin/shows">Shows</a>
    <a href="/admin/visuals">Visuals</a>
    <a href="/admin/generation">Generate</a>
    <div style="flex:1"></div>
    <%= link_to "Sign out", admin_logout_path, method: :delete, style: "font-size:12px;color:rgba(216,212,203,0.25);margin-top:auto" %>
  </nav>
  <main>
    <% if notice %>
      <div class="flash notice"><%= notice %></div>
    <% end %>
    <%= yield %>
  </main>
</body>
</html>
