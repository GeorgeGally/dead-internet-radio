<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIR Control · sign in</title>
  <%= csrf_meta_tags %>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      background: #f5f5f0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1a1a1a;
    }
    .card {
      width: 340px;
    }
    .mark {
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.25);
      margin-bottom: 32px;
    }
    .mark span {
      color: #d45a1f;
    }
    label {
      display: block;
      font-size: 11px;
      color: rgba(0,0,0,0.4);
      margin-bottom: 4px;
    }
    input {
      width: 100%;
      font-family: inherit;
      font-size: 15px;
      padding: 10px 0;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(0,0,0,0.1);
      color: #1a1a1a;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus {
      border-bottom-color: #d45a1f;
    }
    input:-webkit-autofill {
      -webkit-text-fill-color: #1a1a1a;
      -webkit-box-shadow: 0 0 0 30px #f5f5f0 inset;
    }
    .field {
      margin-bottom: 24px;
    }
    .submit-btn {
      width: 100%;
      margin-top: 8px;
      font-family: inherit;
      font-size: 13px;
      padding: 12px;
      background: #1a1a1a;
      color: #f5f5f0;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .submit-btn:hover {
      opacity: 0.85;
    }
    .error {
      font-size: 13px;
      color: #d45a1f;
      margin-bottom: 20px;
    }
    .foot {
      margin-top: 24px;
      font-size: 11px;
      color: rgba(0,0,0,0.2);
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="mark">DIR <span>Control</span></div>
    <%= yield %>
    <div class="foot">dead internet radio</div>
  </div>
</body>
</html>
