<% if @job.running? %>
  <meta http-equiv="refresh" content="5">
  <script>window.addEventListener('load', function() { var el = document.getElementById('output-log'); if (el) el.scrollTop = el.scrollHeight; });</script>
<% end %>

<div class="tx-page">
  <div class="job-detail">
    <h2>Job: <%= @job.slot %></h2>

    <div class="job-info">
      <span class="status-badge status-<%= @job.status %>"><%= @job.status %></span>
      <span><%= @job.track_count %> tracks</span>
      <% if @job.dj_name %><span>DJ: <%= @job.dj_name %></span><% end %>
      <% if @job.dry_run? %><span>Dry run</span><% end %>
      <% if @job.running? %><span class="pulse-dot">&#9679;</span><% end %>
    </div>

    <div class="job-times">
      <span>Started: <%= @job.started_at&.strftime("%Y-%m-%d %H:%M:%S") %></span>
      <span>Completed: <%= @job.completed_at&.strftime("%Y-%m-%d %H:%M:%S") || "—" %></span>
    </div>

    <% if @job.running? %>
      <p class="job-running">Running… auto-refreshing every 5s</p>
    <% end %>

    <% if @job.show %>
      <p class="job-show-link">
        Show: <a href="/admin/shows/<%= @job.show.id %>"><%= @job.show.name || @job.show.slot %></a>
      </p>
    <% end %>

    <% if @job.output_log.present? %>
      <h3>Output</h3>
      <pre id="output-log"><%= @job.output_log %></pre>
    <% end %>

    <div class="job-actions">
      <a href="/admin/generation" class="btn">&larr; Back</a>
      <% if @job.done? %>
        <a href="/admin/generation/new" class="btn">+ New generation</a>
      <% end %>
    </div>
  </div>
</div>
