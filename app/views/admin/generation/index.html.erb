<h2>Generation Jobs</h2>

<p><a href="/admin/generation/new" class="btn" style="display:inline-block;text-decoration:none;">+ New Generation</a></p>

<table>
  <tr><th>Slot</th><th>Tracks</th><th>Status</th><th>Started</th><th>Completed</th></tr>
  <% @jobs.each do |job| %>
    <tr>
      <td><a href="/admin/generation/<%= job.id %>"><%= job.slot %></a></td>
      <td><%= job.track_count %></td>
      <td><span class="status-badge status-<%= job.status %>"><%= job.status %></span></td>
      <td><%= job.started_at&.strftime("%Y-%m-%d %H:%M") %></td>
      <td><%= job.completed_at&.strftime("%Y-%m-%d %H:%M") %></td>
    </tr>
  <% end %>
</table>
